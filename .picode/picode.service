[Unit]
Description=Picode Remote Control Sessions
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/picode start
ExecStop=%h/.local/bin/picode stop
RemainAfterExit=yes
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
